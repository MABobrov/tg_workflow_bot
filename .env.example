# Telegram
BOT_TOKEN=123456:ABCDEF_YOUR_TOKEN
ADMIN_IDS=111111111,222222222

# Storage
DB_PATH=./data/bot.sqlite3
TIMEZONE=Europe/Moscow

# Optional: group chat for notifications (use negative ID like -100123...)
WORK_CHAT_ID=

# Defaults (optional): telegram user IDs for roles
DEFAULT_RP_ID=
DEFAULT_TD_ID=
DEFAULT_ACCOUNTING_ID=
DEFAULT_DRIVER_ID=
DEFAULT_TINTER_ID=
DEFAULT_GD_ID=

# Defaults by username (alternative to IDs)
DEFAULT_RP_USERNAME=
DEFAULT_TD_USERNAME=
DEFAULT_ACCOUNTING_USERNAME=
DEFAULT_DRIVER_USERNAME=
DEFAULT_TINTER_USERNAME=
DEFAULT_GD_USERNAME=

# Reminders
REMINDERS_ENABLED=true
REMIND_SOON_MINUTES=60
REMIND_OVERDUE_MINUTES=10

# Google Sheets integration (optional)
SHEETS_ENABLED=false
GSHEET_SPREADSHEET_ID=YOUR_SPREADSHEET_ID
GSHEET_PROJECTS_TAB=Projects
GSHEET_TASKS_TAB=Tasks

# Provide ONE of:
# 1) raw json (or base64 json) of Google Service Account key
GOOGLE_SERVICE_ACCOUNT_JSON=
# 2) path to json file inside container/host
GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/google-sa.json

# Sheets webhook (real-time commands from Google Sheets)
SHEETS_WEBHOOK_SECRET=77
SHEETS_WEBHOOK_PORT=8443

# amoCRM / Kommo integration (optional)
AMOCRM_ENABLED=false
AMOCRM_BASE_URL=https://subdomain.amocrm.ru
# Minimal mode: only access token (works until token expires)
AMOCRM_ACCESS_TOKEN=
# Auto-refresh mode: set refresh token + OAuth credentials below
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=
AMOCRM_REFRESH_TOKEN=
